{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": [
        "src/data/*.json",
        "firebase-applet-config.json",
        "dist/server.cjs"
      ]
    }
  }
}

